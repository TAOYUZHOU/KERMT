.gitnexus

# ── HARP local-only artefacts (must NOT enter git) ────────────────
# Anything in this block is local scratch for HARP / dev workflow.
# Listing them here doubles as a hard-stop against `git add -A` from
# either the user OR the auto-research agent.

# Manual file backups (e.g. `cp foo.py foo.py.bak` before editing).
*.bak

# Cursor / Claude IDE state — local-only, machine-specific.
.claude/
.cursor/
AGENTS.md
CLAUDE.md

# GitNexus knowledge-graph data + snapshots — regenerated by `analyze`.
.gitnexus.kuzu-backup-*/
.gitnexusignore

# Pretrained-model binaries (large, immutable, fetched separately).
pretrained_models/

# Local smoke / scratch experiments not part of the auto-research loop.
test_run/
smoke_test.sh
troubleshooting.md
data_pipeline.md

# Training outputs — managed by HARP via plan.md / log.md / memory.md,
# not by upstream git.  Keep them on disk for parse_log.py to read,
# but never commit them.
tlc/results/

# Heavy archives of older experiment snapshots (~415MB; .pt models +
# parity plots + predictions CSVs).  Kept on disk for posterity, not
# in git history.
tlc/archive/

# Datasets — should live in DVC / object storage / a separate "data"
# repo, not in source control.  Listed here so a wide `git add -A`
# from the agent can't accidentally inflate the repo.
tlc/data/
tlc/data_v2_cleaned/
tlc/merged_data_*/
tlc/mo_data_*/

# Inference deliverable bundles (large artifacts, not source).  If you
# add new source-y inference code, put it under add_by_HARP/eval/ or
# extend tlc/inference_packages/ at the top level (orchestration
# scripts only — heavy bundle subdirs stay ignored).
tlc/inference_packages/

# tlc/optimize_eval/ — small evaluation harness (~70 KB total, all
# source).  Track everything except caches and binary smoke artifacts.
tlc/optimize_eval/__pycache__/
tlc/optimize_eval/**/__pycache__/
tlc/optimize_eval/smoke_data/
